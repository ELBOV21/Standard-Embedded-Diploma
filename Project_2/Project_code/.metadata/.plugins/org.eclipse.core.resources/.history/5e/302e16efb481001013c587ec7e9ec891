#include <avr/io.h>
#include <avr/interrupt.h>

ISR(TIMER1_COMPA_vect)
{
    PORTD ^= (1 << PD5);   // Toggle LED every 1 sec
}

int main(void)
{
    DDRD |= (1 << PD5);    // PD4 as output
    PORTD &= ~(1 << PD5);

    // Timer1 CTC mode, 1 second interrupt
    TCNT1 = 0;
    OCR1A = 15624;
    TIMSK |= (1 << OCIE1A);
    TCCR1A = 0;
    TCCR1B = (1 << WGM12) | (1 << CS12) | (1 << CS10);

    sei();

    while (1)
    {
        // main loop does nothing
    }
}
