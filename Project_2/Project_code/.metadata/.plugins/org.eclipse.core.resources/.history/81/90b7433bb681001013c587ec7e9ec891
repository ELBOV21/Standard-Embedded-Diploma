#include <avr/io.h>
#include <avr/interrupt.h>
#include <util/delay.h>
#define TICKS_PER_SEC 15624
enum Mode {
    Count_down, Count_up
};
enum Mode Timer_mode = Count_up;

unsigned char hours=0, mins=0, seconds=0;

void Setup_display()
{
    DDRC |= 0x0F;   // decoder input (BCD to 7-seg)
    PORTC &= 0xF0;

    DDRA |= 0x3F;   // digit enable pins
    PORTA |= 0x3F;  // disable all digits initially
}

// Refresh a single digit
void Display_Digit(unsigned char digit, unsigned char value)
{
    PORTA &= 0xC0;         // disable all digits
    PORTA |= (1<<digit);   // enable one digit
    PORTC &= 0xF0;         // clear old value
    PORTC |= (value & 0x0F); // send new BCD value
}

// Update time once per second
ISR(TIMER1_COMPA_vect)
{
    if (Timer_mode == Count_up) {
        seconds++;
        if(seconds >= 60) { seconds = 0; mins++; }
        if(mins >= 60)    { mins = 0; hours++; }
        if(hours >= 60)   { hours = 0; }
    }
}

void Timer1_Init_COMP_Mode()
{
    TCNT1 = 0;
    OCR1A = TICKS_PER_SEC;               // 1 second (16MHz / 1024)
    TIMSK |= (1<<OCIE1A);        // enable compare A interrupt
    TCCR1A = (1<<FOC1A);
    TCCR1B = (1<<WGM12) | (1<<CS12) | (1<<CS10); // CTC, clk/1024
}

int main()
{
    Setup_display();
    sei();
    Timer1_Init_COMP_Mode();

    unsigned char current_digit = 0;

    while(1)
    {
        // refresh each digit quickly
        switch(current_digit) {
            case 0: Display_Digit(PA0, hours/10); break;
            case 1: Display_Digit(PA1, hours%10); break;
            case 2: Display_Digit(PA2, mins/10);  break;
            case 3: Display_Digit(PA3, mins%10);  break;
            case 4: Display_Digit(PA4, seconds/10); break;
            case 5: Display_Digit(PA5, seconds%10); break;
        }
        current_digit = (current_digit + 1) % 6;

        _delay_ms(2); // small delay for persistence of vision
    }
}
