#include "lm35_sensor.h"
#include "../MCAL/adc.h"

/*
 * Description :
 * Function responsible for calculate the temperature from the ADC digital value.
 */
uint8 LM35_getTemperature(void)
{
    uint16 adc_value = 0;
    uint8 temp_value = 0;

    /* Read ADC channel where the temperature sensor is connected */
    adc_value = ADC_read(SENSOR_CHANNEL_ID);

    /* LM35: 10mV per °C
     * ADC equation: (ADC_value / ADC_MAX) * Vref
     * Temperature = (ADC_value * Vref(mV)) / (ADC_max * 10)
     */
    temp_value = (uint8)(((uint32)adc_value * ADC_REF_VOLT_VALUE * SENSOR_MAX_TEMPERATURE)
                        / (ADC_MAXIMUM_VALUE * SENSOR_MAX_VOLT_VALUE));

    return temp_value;
}
